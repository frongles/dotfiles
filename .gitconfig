[core]
	excludesfile = /Users/frasercrumpler/.gitignore
    editor = nvim
    pager = delta
	whitespace = trail,space-before-tab
	commitGraph = true
[user]
	email = fraserc@xacom.com.au
    name = Fraser Crumpler
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    side-by-side = true
[merge]
    conflictStyle = zdiff3
	ff = true
[format]
	pretty = oneline
[log]
    abbrevCommit = true
[branch]
    sort = -committerdate
[tag]
    sort = version:refname
[color]
    ui = auto
[status]
    showStash = true
[commit]
    verbose = true
	template = /Users/frasercrumpler/.gitmessage
[diff]
	colorMoved = default
    algorithm = histogram
    mnemonicPrefix = true   # i/ w/ c/ instead of a/ b/ — tells you index vs worktree vs commit
    renames = copies        # detect copies, not just renames
[diff "rust"]
    xfuncname = "^[ \t]*(pub|fn|impl|struct|enum|trait|mod)[^;]*$"
[push]
    autoSetupRemote = true
    followTags = true
[alias]
    mg = merge --no-commit
	st = status -sb
	co = checkout
	br = branch -av
    lg = log --decorate --graph --all --date=short \
        --pretty=format:'%>|(5)%C(dim white) %ad %<(15,trunc)%an %Creset  %C(yellow)%h%Creset %C(auto)%d%Creset %s'
    lga = log --stat --pretty=fuller --graph --all
    pf = push --force-with-lease --force-if-includes
    #git diff --stat a1b2c3d..HEAD -- ':(exclude)dist/'
[apply]
	whitespace = error
[fetch]
    verbose = true
    prune = true
    pruneTags = true
